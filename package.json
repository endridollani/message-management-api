{
  "name": "message-management-api",
  "version": "0.0.1",
  "private": true,
  "description": "Production-grade message management backend scaffold.",
  "license": "UNLICENSED",
  "scripts": {
    "build": "npm run build:api && npm run build:outbox-publisher && npm run build:search-indexer && npm run build:cli && npm run typecheck",
    "build:api": "nest build api",
    "build:outbox-publisher": "nest build outbox-publisher",
    "build:search-indexer": "nest build search-indexer",
    "build:cli": "nest build cli",
    "format": "prettier --write \"{apps,libs,test}/**/*.ts\" \"*.{js,json,md}\" \"docs/**/*.md\"",
    "format:check": "prettier --check \"{apps,libs,test}/**/*.ts\" \"*.{js,json,md}\" \"docs/**/*.md\"",
    "lint": "eslint \"{apps,libs,test}/**/*.ts\"",
    "start": "nest start api",
    "start:dev": "nest start api --watch",
    "start:debug": "nest start api --debug --watch",
    "start:prod": "node dist/apps/api/main.js",
    "start:outbox-publisher": "nest start outbox-publisher",
    "start:search-indexer": "nest start search-indexer",
    "start:cli": "nest start cli",
    "test": "jest --passWithNoTests",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "@nestjs/common": "^11.1.6",
    "@nestjs/core": "^11.1.6",
    "@nestjs/platform-express": "^11.1.6",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2"
  },
  "overrides": {
    "multer": "^2.2.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.30.1",
    "@nestjs/cli": "^11.0.7",
    "@nestjs/schematics": "^11.0.5",
    "@nestjs/testing": "^11.1.6",
    "@types/jest": "^29.5.14",
    "@types/node": "^22.13.0",
    "eslint": "^9.30.1",
    "eslint-config-prettier": "^10.1.5",
    "globals": "^16.2.0",
    "jest": "^29.7.0",
    "prettier": "^3.6.2",
    "source-map-support": "^0.5.21",
    "ts-jest": "^29.2.5",
    "ts-loader": "^9.5.2",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.35.1"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": ".",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "apps/**/*.ts",
      "libs/**/*.ts"
    ],
    "coverageDirectory": "./coverage",
    "testEnvironment": "node",
    "moduleNameMapper": {
      "^@app/(.*)$": "<rootDir>/libs/$1/src"
    }
  },
  "packageManager": "pnpm@11.1.1+sha512.d1fdf5f73c617b64fa1a56a81c3c8dfe0e966e33a6010aa256b517ae77be21d93e05affc0de1a83b0e4f29d569f68b446ae8f068cd7247c0bb3df0fb4d7bdf9a"
}
