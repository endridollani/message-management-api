{
  "name": "message-management-api",
  "version": "0.0.1",
  "private": true,
  "description": "Production-grade message management backend scaffold.",
  "license": "UNLICENSED",
  "packageManager": "pnpm@11.1.1",
  "scripts": {
    "build": "pnpm run build:api && pnpm run build:outbox-publisher && pnpm run build:search-indexer && pnpm run build:cli && pnpm run typecheck",
    "build:api": "nest build api",
    "build:outbox-publisher": "nest build outbox-publisher",
    "build:search-indexer": "nest build search-indexer",
    "build:cli": "nest build cli",
    "format": "prettier --write \"{apps,libs,test}/**/*.ts\" \"*.{js,json,md}\" \"docs/**/*.md\"",
    "format:check": "prettier --check \"{apps,libs,test}/**/*.ts\" \"*.{js,json,md}\" \"docs/**/*.md\"",
    "lint": "eslint \"{apps,libs,test}/**/*.ts\"",
    "start": "nest start api",
    "start:dev": "nest start api --watch",
    "start:debug": "nest start api --debug --watch",
    "start:prod": "node dist/apps/api/apps/api/src/main.js",
    "start:outbox-publisher": "nest start outbox-publisher",
    "start:search-indexer": "nest start search-indexer",
    "start:cli": "nest start cli",
    "test": "jest --config jest.config.js --passWithNoTests",
    "test:unit": "jest --config test/jest/unit.config.js --passWithNoTests",
    "test:e2e": "jest --config test/jest/e2e.config.js --passWithNoTests",
    "test:integration": "jest --config test/jest/integration.config.js --runInBand --detectOpenHandles",
    "test:ci": "pnpm run test:unit && pnpm run test:e2e && pnpm run test:integration",
    "test:watch": "jest --config jest.config.js --watch",
    "test:cov": "jest --config jest.config.js --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --config jest.config.js --runInBand",
    "typecheck": "tsc --noEmit -p tsconfig.src.json && tsc --noEmit -p tsconfig.spec.json"
  },
  "dependencies": {
    "@elastic/elasticsearch": "^8.14.0",
    "@nestjs/common": "^11.1.6",
    "@nestjs/config": "^4.0.4",
    "@nestjs/core": "^11.1.6",
    "@nestjs/elasticsearch": "^11.1.0",
    "@nestjs/mongoose": "^11.0.4",
    "@nestjs/platform-express": "^11.1.6",
    "@nestjs/swagger": "^11.4.5",
    "@nestjs/terminus": "^11.1.1",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "express": "^5.2.1",
    "joi": "^18.2.3",
    "kafkajs": "^2.2.4",
    "mongoose": "^9.7.3",
    "nest-commander": "^3.20.1",
    "nestjs-pino": "^4.6.1",
    "pino-http": "^11.0.0",
    "prom-client": "^15.1.3",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2"
  },
  "devDependencies": {
    "@eslint/js": "^9.30.1",
    "@nestjs/cli": "^11.0.7",
    "@nestjs/schematics": "^11.0.5",
    "@nestjs/testing": "^11.1.6",
    "@types/express": "^5.0.6",
    "@types/jest": "^29.5.14",
    "@types/node": "^22.13.0",
    "@types/supertest": "^7.2.0",
    "eslint": "^9.30.1",
    "eslint-config-prettier": "^10.1.5",
    "globals": "^16.2.0",
    "jest": "^29.7.0",
    "mongodb-memory-server": "^11.2.0",
    "prettier": "^3.6.2",
    "source-map-support": "^0.5.21",
    "supertest": "^7.2.2",
    "testcontainers": "^12.0.4",
    "ts-jest": "^29.2.5",
    "ts-loader": "^9.5.2",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.35.1"
  }
}
