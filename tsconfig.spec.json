{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "composite": true,
    "noEmit": true,
    "tsBuildInfoFile": "./dist/tsconfig.spec.tsbuildinfo",
    "types": ["node", "jest"]
  },
  "include": [
    "apps/**/*.ts",
    "libs/**/*.ts",
    "apps/**/*.spec.ts",
    "libs/**/*.spec.ts",
    "test/**/*.ts",
    "test/*.spec.ts"
  ],
  "exclude": ["node_modules", "dist"]
}
